# =============================================================================
#  CONFIGURAÇÃO DO VIDEO-CONVERTER
# =============================================================================
#  Como usar:
#    1. Copie este arquivo para ".env"  (ex.: cp .env.example .env)
#    2. Edite os valores abaixo (no mínimo, INPUT_DIR e OUTPUT_DIR)
#    3. Rode o programa:  ./video-converter
#
#  Linhas que começam com "#" são comentários e são ignoradas.
#  O que você não quiser mudar, pode deixar como está (os padrões já são bons).
#  Obs.: uma flag na linha de comando sempre vence o que estiver aqui.
# =============================================================================

# -----------------------------------------------------------------------------
#  PASTAS (obrigatórias)
# -----------------------------------------------------------------------------
# INPUT_DIR  = a PASTA onde estão os seus vídeos originais.
#              O programa olha dentro dela E dentro de todas as subpastas,
#              e converte TODOS os vídeos que encontrar. (É uma pasta, não um arquivo.)
#
# OUTPUT_DIR = a PASTA onde os vídeos convertidos serão salvos.
#              Dentro dela é criada uma subpasta "<nome-da-pasta-de-entrada>_CONV",
#              mantendo a mesma organização de subpastas da entrada.
#
# Exemplo: se INPUT_DIR for "/home/ana/aulas" e tiver "aula01.mp4" e "modulo2/aula02.mp4",
# a saída fica em "<OUTPUT_DIR>/aulas_CONV/aula01.mp4" e ".../aulas_CONV/modulo2/aula02.mp4".
#
# Dica: caminhos com espaço NÃO precisam de aspas aqui no .env.
INPUT_DIR=./in
OUTPUT_DIR=./out

# -----------------------------------------------------------------------------
#  ONDE PROCESSAR: placa de vídeo (GPU) ou processador (CPU)
# -----------------------------------------------------------------------------
# Usar a GPU é MUITO mais rápido. "auto" descobre sozinho o que sua máquina tem.
#
#   auto          -> recomendado. Detecta e usa a melhor GPU disponível;
#                    se não houver GPU utilizável, usa a CPU automaticamente.
#   cpu           -> força usar o processador (bom se sua GPU for fraca).
#   nvenc         -> placa NVIDIA (Windows/Linux)
#   qsv           -> Intel Quick Sync (Windows/Linux)
#   amf           -> placa AMD (Windows)
#   vaapi         -> placa AMD/Intel (Linux)
#   videotoolbox  -> Mac (aceleração da Apple)
#
# Importante: "auto" escolhe por DISPONIBILIDADE, não por velocidade. Se você tem
# uma GPU fraca e um processador forte, coloque "cpu" para forçar o processador.
BACKEND=auto

# -----------------------------------------------------------------------------
#  QUALIDADE (de 0 a 100) — controla qualidade x tamanho do arquivo
# -----------------------------------------------------------------------------
# Quanto MAIOR o número:  melhor qualidade da imagem, arquivo MAIOR.
# Quanto MENOR o número:  mais compressão (arquivo menor), qualidade um pouco pior.
#
#   85-90  -> qualidade altíssima, arquivo grande
#   60     -> equilíbrio bom (padrão)
#   40-50  -> bem comprimido, arquivo pequeno (ótimo p/ economizar espaço)
#
# Pra COMPRIMIR MAIS (arquivo menor), DIMINUA esse número.
QUALITY=60


# -----------------------------------------------------------------------------
#  FRAME RATE (quadros por segundo)
# -----------------------------------------------------------------------------
# Limita a taxa de quadros do vídeo de saída. Para vídeos de tela/código,
# baixar o frame rate reduz bastante o tamanho sem perda perceptível.
#
#   30 -> padrão (bom para a maioria)
#   20 -> ainda menor (ótimo p/ gravações de tela/código)
#   0  -> manter o frame rate original (não mexe)
#
# Observação: NUNCA aumenta. Um vídeo a 24 fps continua 24 fps.
FPS=30


# -----------------------------------------------------------------------------
#  RESOLUÇÃO / ESCALA (altura máxima em pixels)
# -----------------------------------------------------------------------------
# Redimensiona o vídeo para no máximo essa ALTURA, mantendo a proporção.
#
#   1080 -> padrão (Full HD)
#   720  -> menor (HD, arquivos bem menores)
#   1440 -> maior (2K), 2160 (4K)
#   0    -> manter o tamanho original (não redimensiona)
#
# Observação: NUNCA aumenta. Um vídeo 720p não é esticado para 1080p.
SCALE=1080


# -----------------------------------------------------------------------------
#  ÁUDIO
# -----------------------------------------------------------------------------
# O áudio é sempre COPIADO do original (sem reencodar): rápido e sem perda.
# Não há nada para configurar aqui.


# -----------------------------------------------------------------------------
#  FORMATO DO VÍDEO (codec)
# -----------------------------------------------------------------------------
#   h264 -> padrão. Toca em praticamente qualquer lugar (máxima compatibilidade).
#   hevc -> arquivo ~30-50% menor que h264 na mesma qualidade (H.265).
#   av1  -> comprime ainda mais, porém é mais lento e menos compatível em players antigos.
#
# Para arquivos menores mantendo a qualidade, experimente "hevc".
CODEC=h264


# -----------------------------------------------------------------------------
#  INTENSIDADE — o quanto o programa "puxa" da sua máquina
# -----------------------------------------------------------------------------
#   light    -> leve: usa pouco da máquina, dá pra trabalhar normalmente enquanto roda.
#   balanced -> equilíbrio (padrão): usa cerca de metade da máquina.
#   max      -> máximo: mais rápido / comprime melhor, mas deixa a máquina pesada.
INTENSITY=balanced


# -----------------------------------------------------------------------------
#  SOBRESCREVER vídeos já convertidos?
# -----------------------------------------------------------------------------
#   false -> NÃO refaz o que já foi convertido (pula). Bom pra continuar de onde parou.
#   true  -> refaz tudo, sobrescrevendo a saída existente.
OVERWRITE=false


# =============================================================================
#  CONFIGURAÇÕES AVANÇADAS (a maioria das pessoas NÃO precisa mexer)
# =============================================================================

# Quantos vídeos processar ao mesmo tempo. 0 = o programa decide sozinho
# (na CPU usa vários ao mesmo tempo; na GPU usa poucos, porque não adianta mais).
WORKERS=0

# Limite de "força" do processador por vídeo (só faz efeito quando BACKEND=cpu).
# 0 = o programa calcula sozinho para não travar a máquina.
THREADS=0

# Tipos de arquivo que ele considera "vídeo" na entrada (não diferencia maiúsc/minúsc).
EXTENSIONS=mp4,mov,mkv,avi

# Se você forçar uma GPU e ela não funcionar:
#   true  -> avisa e usa a CPU mesmo assim (não interrompe o trabalho).
#   false -> para com erro (útil só pra confirmar se a GPU está mesmo funcionando).
FALLBACK_ON_FAILURE=true

# Apenas Linux com GPU AMD/Intel: qual dispositivo de vídeo usar. Mude só se der erro.
VAAPI_DEVICE=/dev/dri/renderD128

# Prioridade do processo (Linux/Mac). 0 = normal. Número maior = "menos pressa"
# (deixa outros programas na frente). Deixe 0 se não souber.
NICE=0

# Onde salvar os logs caso algum vídeo dê erro (a pasta só é criada se houver erro).
# Padrão: "logs" na pasta de onde você roda o programa. Pode apontar para outro caminho.
LOG_DIR=logs
